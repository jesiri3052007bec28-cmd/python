mport re

structure_pattern = r"^[456]\d{3}(-?\d{4}){3}$"

repeat_pattern = r"(.)\1{3,}"

for _ in range(int(input())):
    card_number = input().strip()

    if re.fullmatch(structure_pattern, card_number):

        raw_digits = card_number.replace("-", "")
        
        if not re.search(repeat_pattern, raw_digits):
            print("Valid")
        else:
            print("Invalid")
    else:
        print("Invalid")
