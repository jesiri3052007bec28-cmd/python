from collections import deque
import sys

d = deque()

try:
    n = int(sys.stdin.readline())
except ValueError:
    n = 0

for _ in range(n):
    line = sys.stdin.readline().split()
    if not line:
        break
        
    command = line[0]
    
    if len(line) > 1:
        value = line[1]
    
        getattr(d, command)(value)
    else:
    
        getattr(d, command)()


print(*(d))
