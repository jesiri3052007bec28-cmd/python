import re
import email.utils
pattern = r'^[A-Za-z][A-Za-z0-9-._]*@[A-Za-z]+\.[A-Za-z]{1,3}$'
n = int(input())
for _ in range(n):
    name_addr_pair = input()
    name, email_addr = email.utils.parseaddr(name_addr_pair)
    if re.match(pattern, email_addr):
        print(email.utils.formataddr((name, email_addr)))
